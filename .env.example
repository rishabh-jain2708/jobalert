# Optional Telegram alerts.
# Create a bot with BotFather, message it once, then set these as GitHub secrets.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional generic webhook endpoint for tools like Slack/Discord/Zapier.
WEBHOOK_URL=

# Optional override. Defaults to config/settings.json.
FREELANCE_BOT_SETTINGS=config/settings.json

